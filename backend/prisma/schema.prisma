generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Colaborador {
  id            Int            @id @default(autoincrement())
  matricula     String         @unique
  nome          String
  email         String         @unique
  cargo         String?
  departamento  String?
  ativo         Boolean        @default(true)
  criadoEm      DateTime       @default(now()) @map("criado_em")
  atualizadoEm  DateTime       @updatedAt @map("atualizado_em")
  participacoes Participacao[]

  @@map("colaboradores")
}

model Treinamento {
  id            Int            @id @default(autoincrement())
  titulo        String
  descricao     String?
  cargaHoraria  Int            @map("carga_horaria")
  modalidade    String         @default("presencial")
  status        String         @default("planejado")
  dataInicio    DateTime?      @map("data_inicio")
  dataFim       DateTime?      @map("data_fim")
  criadoEm      DateTime       @default(now()) @map("criado_em")
  atualizadoEm  DateTime       @updatedAt @map("atualizado_em")
  participacoes Participacao[]

  @@map("treinamentos")
}

model Participacao {
  id             Int         @id @default(autoincrement())
  colaboradorId  Int         @map("colaborador_id")
  treinamentoId  Int         @map("treinamento_id")
  statusPresenca String      @default("inscrito") @map("status_presenca")
  nota           Float?
  certificado    Boolean     @default(false)
  criadoEm       DateTime    @default(now()) @map("criado_em")
  atualizadoEm   DateTime    @updatedAt @map("atualizado_em")
  colaborador    Colaborador @relation(fields: [colaboradorId], references: [id])
  treinamento    Treinamento @relation(fields: [treinamentoId], references: [id])

  @@unique([colaboradorId, treinamentoId])
  @@map("participacoes")
}

model DiscLink {
  id              String   @id @default(uuid())
  isEmployee      Boolean  @default(true)
  companyId       String?
  branchId        String?
  status          String   @default("PENDING")
  isActive        Boolean  @default(true) @map("is_active")
  expiraEm        DateTime @map("expira_em")
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")
  cpf             String?
  nome            String?
  respostas       Json?
  resultado       Json?
  departamentCode        String?  @map("departament_code")
  departmentDescription  String?  @map("department_description")

  @@map("disc_links")
}

enum Role {
  USER
  GESTOR
  RH
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String            @id @default(uuid())
  username        String            @unique
  cpf             String?           @unique
  name            String?
  role            Role              @default(USER)
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  departamentCode String?           @map("departament_code")
  empresaId       String?           @map("empresa_id") @db.VarChar
  filialId        String?           @map("filial_id") @db.VarChar

  managedDepts    ManagerDepartment[]
  accessRequests  AccessRequest[]

  @@map("users")
}

// Vínculos Oficiais (Solução 1)
model ManagerDepartment {
  id             String @id @default(uuid())
  userId         String @map("user_id")
  departmentCode String @map("department_code")
  departmentName String @map("department_name")
  
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentCode])
  @@map("manager_departments")
}

// Fila de Aprovação (Solução 2)
model AccessRequest {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  requestedDepts     Json          @map("requested_depts") // Array de objetos: [{ code: "001", name: "T.I." }]
  status             RequestStatus @default(PENDING)
  justification      String?
  requestedEmpresaId String?       @map("requested_empresa_id")
  requestedFilialId  String?       @map("requested_filial_id")
  
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt          DateTime      @default(now()) @map("created_at")
  resolvedAt         DateTime?     @map("resolved_at")
  resolvedBy         String?       @map("resolved_by") // Id do Admin

  @@map("access_requests")
}

// Cache de Departamentos — populado organicamente quando DISCs são concluídos
model Department {
  id                    String   @id @default(uuid())
  departmentCode        String   @map("department_code")
  departmentDescription String   @map("department_description")
  empresaId             String   @map("empresa_id")
  filialId              String   @map("filial_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([departmentCode, empresaId, filialId])
  @@map("departments")
}
