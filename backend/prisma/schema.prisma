generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Colaborador {
  id            Int            @id @default(autoincrement())
  matricula     String         @unique
  nome          String
  email         String         @unique
  cargo         String?
  departamento  String?
  ativo         Boolean        @default(true)
  criadoEm      DateTime       @default(now()) @map("criado_em")
  atualizadoEm  DateTime       @updatedAt @map("atualizado_em")
  participacoes Participacao[]

  @@map("colaboradores")
}

model Treinamento {
  id            Int            @id @default(autoincrement())
  titulo        String
  descricao     String?
  cargaHoraria  Int            @map("carga_horaria")
  modalidade    String         @default("presencial")
  status        String         @default("planejado")
  dataInicio    DateTime?      @map("data_inicio")
  dataFim       DateTime?      @map("data_fim")
  criadoEm      DateTime       @default(now()) @map("criado_em")
  atualizadoEm  DateTime       @updatedAt @map("atualizado_em")
  participacoes Participacao[]

  @@map("treinamentos")
}

model Participacao {
  id             Int         @id @default(autoincrement())
  colaboradorId  Int         @map("colaborador_id")
  treinamentoId  Int         @map("treinamento_id")
  statusPresenca String      @default("inscrito") @map("status_presenca")
  nota           Float?
  certificado    Boolean     @default(false)
  criadoEm       DateTime    @default(now()) @map("criado_em")
  atualizadoEm   DateTime    @updatedAt @map("atualizado_em")
  colaborador    Colaborador @relation(fields: [colaboradorId], references: [id])
  treinamento    Treinamento @relation(fields: [treinamentoId], references: [id])

  @@unique([colaboradorId, treinamentoId])
  @@map("participacoes")
}

model DiscLink {
  id              String   @id @default(uuid())
  isEmployee      Boolean  @default(true)
  companyId       String?
  branchId        String?
  status          String   @default("PENDING")
  isActive        Boolean  @default(true) @map("is_active")
  expiraEm        DateTime @map("expira_em")
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")
  cpf             String?
  nome            String?
  respostas       Json?
  resultado       Json?
  departamentCode String?  @map("departament_code")

  @@map("disc_links")
}

model User {
  id              String   @id @default(uuid())
  username        String   @unique
  role            String   @default("RH")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  departamentCode String?  @map("departament_code")
  empresaId       String?  @map("empresa_id") @db.VarChar
  filialId        String?  @map("filial_id") @db.VarChar

  @@map("users")
}
